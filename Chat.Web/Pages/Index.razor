@page "/"

<div class="input-group mb-3">  
  <input type="text" @bind-value="@Message" class="form-control" placeholder="Username" aria-label="Username" aria-describedby="basic-addon1">
</div>

<button type="button" class="btn btn-primary" @onclick="SendMessage">Enviar</button>

@foreach (var message in Messages)
{
  <h1>@message</h1>	
}